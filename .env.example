# Server
PORT=8003
NODE_ENV=development

# Database (required)
# For local development with Docker: postgresql://ccbricks_user:localdev@localhost:5432/ccbricks
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Databricks (required)
DATABRICKS_HOST=your-workspace.cloud.databricks.com

# Databricks Apps (optional - automatically set in Databricks Apps environment)
DATABRICKS_APP_NAME=
DATABRICKS_WORKSPACE_ID=
DATABRICKS_APP_PORT=8000
# Required when Claude Code telemetry tables are configured.
# The otelHeadersHelper uses these credentials to refresh Databricks OTel auth headers.
DATABRICKS_CLIENT_ID=
DATABRICKS_CLIENT_SECRET=

# SQL Warehouse IDs (optional)
WAREHOUSE_ID=

# ccbricks base directory (optional - users/, sessions/, db/ created underneath)
CCBRICKS_BASE_DIR=

# Development: Databricks headers for local testing (required for local development)
# These are used by the Vite dev proxy to simulate Databricks Apps environment
DATABRICKS_TOKEN=your-personal-access-token
DATABRICKS_USER_NAME=your-name
DATABRICKS_USER_ID=your-user-id
DATABRICKS_USER_EMAIL=your-email@example.com
